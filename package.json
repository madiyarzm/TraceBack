{
  "name": "traceback-ai",
  "displayName": "TraceBack \u2014 AI Agent Observability",
  "description": "Live timeline, anomaly detection, breakpoints, and tripwires for AI coding agents. Watch, pause, and steer Claude Code sessions from your sidebar.",
  "version": "0.1.1",
  "publisher": "madiyarzhunussov",
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#07090d",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/madiyarzm/TraceBack"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "observability",
    "claude",
    "claude-code",
    "monitoring",
    "anomaly-detection",
    "human-in-the-loop"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "traceback.openMap",
        "title": "TraceBack: Open Action Map"
      },
      {
        "command": "traceback.clearSession",
        "title": "TraceBack: Clear Current Session"
      },
      {
        "command": "traceback.startListening",
        "title": "TraceBack: Start Listening"
      },
      {
        "command": "traceback.stopListening",
        "title": "TraceBack: Stop Listening"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "traceback-sidebar",
          "title": "TraceBack",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "traceback-sidebar": [
        {
          "type": "webview",
          "id": "traceback.mapView",
          "name": "Action Map"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "traceback.openMap",
          "when": "view == traceback.mapView",
          "group": "navigation"
        },
        {
          "command": "traceback.clearSession",
          "when": "view == traceback.mapView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TraceBack",
      "properties": {
        "traceback.port": {
          "type": "number",
          "default": 7777,
          "description": "Local port TraceBack listens on for Claude Code hook events."
        },
        "traceback.autoInstallHooks": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install Claude Code hooks into ~/.claude/settings.json on activation."
        },
        "traceback.llmProvider": {
          "type": "string",
          "enum": [
            "disabled",
            "groq",
            "ollama"
          ],
          "default": "disabled",
          "description": "LLM backend for the Narrative Engine. Set to 'groq' or 'ollama' to enable live summaries and the chat helper."
        },
        "traceback.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key. Get one free at console.groq.com."
        },
        "traceback.groqModel": {
          "type": "string",
          "default": "llama-3.1-8b-instant",
          "description": "Groq model to use for summaries and chat. 'llama-3.1-8b-instant' is fast and free."
        },
        "traceback.ollamaModel": {
          "type": "string",
          "default": "llama3.2",
          "description": "Ollama model to use (must be pulled locally). e.g. 'llama3.2' or 'mistral'."
        },
        "traceback.ollamaPort": {
          "type": "number",
          "default": 11434,
          "description": "Port Ollama is listening on (default 11434)."
        },
        "traceback.tripwires": {
          "type": "array",
          "default": [],
          "description": "Policy rules that block matching agent tool calls before they execute, across all sessions.",
          "items": {
            "type": "object",
            "required": [
              "pattern"
            ],
            "properties": {
              "tool": {
                "type": "string",
                "description": "Regex matched against the tool name (e.g. \"Bash\", \"Edit|Write\"). Omit to match any tool."
              },
              "pattern": {
                "type": "string",
                "description": "Regex (case-insensitive) matched against the tool name + its input JSON. A match blocks the call."
              },
              "reason": {
                "type": "string",
                "description": "Message fed back to the agent explaining why the call was blocked."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd webview && npm run build",
    "dev:webview": "cd webview && npm run dev",
    "package": "vsce package",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.8"
  }
}