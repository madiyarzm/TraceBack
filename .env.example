# TraceBack — local environment template.
# Copy this file to .env and fill in your own values.
# .env is git-ignored; this template is the only env file ever committed.

# ── Narrative Engine (optional) ────────────────────────────────────────────
# TraceBack uses an LLM to summarize agent sessions in plain English and to
# answer follow-up questions in the sidebar chat. Pick ONE backend.

# Option A — Groq (cloud, free tier, no install required).
# Get a key at https://console.groq.com → top-right menu → API Keys.
GROQ_API_KEY=gsk_your_key_here

# Override the default model (optional).
# GROQ_MODEL=llama-3.1-8b-instant

# Option B — Ollama (fully local, no API key, ~3 GB download).
# Install from https://ollama.com, then `ollama pull llama3.2`.
# OLLAMA_MODEL=llama3.2
# OLLAMA_PORT=11434
